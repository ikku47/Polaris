---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import siteConfig from "@/config/site.json";

const projects = await getCollection("projects");
type Project = CollectionEntry<"projects">;

// Sort projects by date in descending order (newest first)
const sortedProjects = projects.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const { projects: projectsConfig } = siteConfig;
const gridCols = projectsConfig.gridColumns || 1;

// Generate dynamic grid classes based on the number of columns
const generateGridClass = (columns: number) => {
  let gridClass = "grid gap-4";

  if (columns === 1) {
    gridClass += " grid-cols-1";
  } else if (columns === 2) {
    gridClass += " grid-cols-1 sm:grid-cols-2";
  } else {
    gridClass += " grid-cols-1 sm:grid-cols-2 xl:grid-cols-3";
  }

  return gridClass;
};

const gridClass = generateGridClass(gridCols);

const getEagerLoadCount = (columns: number) => {
  const maxColumns = Math.min(columns, 3);
  return 3 * maxColumns;
};

const eagerLoadCount = getEagerLoadCount(gridCols);
---

<div class={gridClass}>
  {
    sortedProjects.map((project: Project, index: number) => (
      <a
        href={`/projects/${project.id}`}
        class="group relative rounded-lg lg:rounded-2xl overflow-hidden bg-gray-100 transition-all duration-500 ease-out hover:scale-[1.02] hover:shadow-xl aspect-[16/10]"
      >
        <Image
          alt={project.data.coverAlt}
          loading={index < eagerLoadCount ? "eager" : "lazy"}
          width="3552"
          height="2304"
          decoding="async"
          src={project.data.cover}
          class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105"
          transition:name={`project-${project.id}`}
        />
        
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="absolute bottom-4 left-4 right-4 items-center gap-2 flex translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 ease-out">
          <div class="shrink-0 shadow-lg">
            <Image
              src={project.data.logo.image}
              width="32"
              height="32"
              alt={`${project.data.name} logo`}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="w-8 h-8 rounded-full object-cover border-2 border-white/20"
              onerror="this.style.display='none';this.nextElementSibling.classList.remove('hidden')"
            />
            <div
              class={`w-8 h-8 ${project.data.logo.fallback.bgColor} rounded-full hidden items-center justify-center text-white text-xs border-2 border-white/20`}
            >
              {project.data.logo.fallback.text}
            </div>
          </div>
          <div class="flex flex-col">
            <div class="text-sm font-bold text-white tracking-tight leading-none">
              {project.data.name}
            </div>
            <div class="text-[10px] text-white/70 font-medium tracking-wide uppercase mt-1">
              View Case Study
            </div>
          </div>
        </div>
      </a>
    ))
  }
</div>
